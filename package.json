{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "snapshot": "git add -A && git commit -m \"snapshot: $(date '+%Y-%m-%d %H:%M')\" --allow-empty",
    "dev": "npm run snapshot && tsx server/index.ts",
    "prebuild": "node scripts/validate_gemini_calls.js",
    "build": "vite build",
    "start": "NODE_ENV=production npx tsx server/index.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json",
    "validate:gemini": "node scripts/validate_gemini_calls.js",
    "validate:complexity": "node scripts/check_complexity.js",
    "validate:sds": "node scripts/silent_degradation_sentinel.js",
    "validate:exposure": "node scripts/scan_exposure.js",
    "validate:responsibility": "node scripts/check_responsibility.js",
    "validate:boundary": "node scripts/check_symbol_boundary.js",
    "build:exit-catalog": "node scripts/generate_exit_rules_catalog.js",
    "validate:exit-catalog": "node scripts/generate_exit_rules_catalog.js --check",
    "validate:all": "npm run validate:gemini && npm run validate:complexity && npm run validate:sds && npm run validate:exposure && npm run validate:responsibility && npm run validate:boundary",
    "precommit": "node scripts/check_deploy_window.js && node scripts/scan_exposure.js --no-history && node scripts/check_complexity.js && node scripts/check_responsibility.js --changed && node scripts/check_symbol_boundary.js && npm run validate:gemini && npm run lint",
    "install:hooks": "node scripts/install_git_hooks.js",
    "update:sector-map": "tsx scripts/updateSectorMap.ts"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/query-sync-storage-persister": "^5.96.2",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-query-persist-client": "^5.96.2",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dayjs": "^1.11.20",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jspdf": "^4.2.1",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.546.0",
    "modern-screenshot": "^4.6.8",
    "motion": "^12.23.24",
    "node-cron": "^3.0.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.72.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.17",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.2",
    "@types/ws": "^8.18.1"
  }
}
