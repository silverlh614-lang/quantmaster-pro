# ============================================================
#  QuantMaster Pro — Railway 환경변수 완전 설정 가이드
#  이 파일을 .env로 복사 후 실제 값을 입력하세요.
#  Railway Dashboard → Variables 탭에서 동일하게 설정하세요.
# ============================================================

# ──────────────────────────────────────────────
# [1] KIS (한국투자증권) API 설정
# ──────────────────────────────────────────────

# KIS 앱키 / 앱시크릿 (KIS Developers → 앱 등록 후 발급)
# 처음에는 모의투자(VTS) 계좌 앱키를 사용하세요
KIS_APP_KEY=PSxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KIS_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 계좌번호 — 앞 8자리만 입력 (예: 50123456)
KIS_ACCOUNT_NO=50123456

# 계좌 상품코드 — 일반적으로 01
KIS_ACCOUNT_PROD=01

# true = 실거래, false = 모의투자(VTS)
# ⚠️ 처음에는 반드시 false로 시작하세요!
KIS_IS_REAL=false

# ──────────────────────────────────────────────
# [1-B] 실계좌 데이터 전용 키 (하이브리드 구조, 선택)
# ──────────────────────────────────────────────
# 모의계좌(VTS)로 주문을 집행하면서, 실계좌 키로 시장 데이터를 조회합니다.
# 거래량 순위, 상승률 순위 등 실계좌에서만 제공하는 데이터에 사용됩니다.
# ※ 주문은 절대 실행하지 않으며, 데이터 조회(GET)만 수행합니다.
# ※ 미설정 시 모의계좌 키로 자동 폴백합니다.
KIS_REAL_DATA_APP_KEY=
KIS_REAL_DATA_APP_SECRET=

# ──────────────────────────────────────────────
# [2] 자동매매 제어 설정
# ──────────────────────────────────────────────

# 서버사이드 자동매매 활성화 여부
# Shadow 모드로 충분히 검증한 후 true로 변경하세요
AUTO_TRADE_ENABLED=false

# 클라이언트-서버 중복 주문 방지 플래그
# AUTO_TRADE_ENABLED=true로 설정할 때 이 값도 true로 맞추세요.
# true이면 클라이언트(브라우저)에서의 실주문이 차단되고
# 서버 autoTradeEngine만 주문을 집행합니다.
VITE_AUTO_TRADE_ENABLED=false

# 서버 자동매매 투자 총자산 (원) — 미설정 시 1억원 기본값
# 모의계좌 초기자금에 맞춰 설정하세요 (예: 3천만원 = 30000000)
AUTO_TRADE_ASSETS=30000000

# 1회 최대 포지션 크기 (총 자산 대비 %) — 권장: 5~10
MAX_POSITION_PCT=10

# 일일 손실 한도 (총 자산 대비 %) — 초과 시 긴급 자동 정지
DAILY_LOSS_LIMIT=5

# PR-22 / ADR-0008 — Kelly 시간감쇠 wiring 스위치.
# false 로 두면 accountRiskBudget 가 timeDecayInput 을 받아도 staticKelly 로 단락. 긴급 롤백용.
# KELLY_TIME_DECAY_ENABLED=true

# PR-22 / ADR-0007 — 학습 모듈 하이브리드 suggest 알림 스위치.
# false 로 두면 counterfactual/ledger/kellySurface/regimeCoverage suggest 알림이 전부 차단됨.
# LEARNING_SUGGEST_ENABLED=true

# ──────────────────────────────────────────────
# [3] Gemini AI API (퀀트 스크리닝용)
# ──────────────────────────────────────────────

GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────
# [4] DART 공시 알림 (선택)
# ──────────────────────────────────────────────

# DART Open API 키 (dart.fss.or.kr → 인증키 신청)
DART_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────
# [4-B] KRX Open API (한국거래소 인증키)
# ──────────────────────────────────────────────
# openapi.krx.co.kr → 마이페이지 → API 인증키 신청 후 승인된 서비스 호출용.
# 미설정 시 서버는 즉시 Yahoo Finance 로 폴백합니다 (기능 중단 없음).
# 승인된 서비스 (2026-04 기준, 사용자 계정):
#   - 유가증권 일별매매정보, 코스닥 일별매매정보
#   - 유가증권 종목기본정보, 코스닥 종목기본정보
#   - KOSPI/KOSDAQ/KRX 시리즈 일별시세, 파생상품지수 시세
# 주의: 일 10,000회 쿼터 제한 — 서버는 15분 캐시 + 서킷브레이커로 쿼터 보호합니다.
#
# 블루프린트 표준 (권장):
#   KRX_API_KEY  — 인증키 (레거시 KRX_OPENAPI_AUTH_KEY 도 계속 인식)
#   KRX_API_BASE — 기본 http://data-dbg.krx.co.kr. 호스트만 적으면 /svc/apis 자동 부착.
# 두 이름을 모두 설정할 경우 레거시(KRX_OPENAPI_*)가 우선합니다.
KRX_API_KEY=
KRX_API_BASE=http://data-dbg.krx.co.kr

# 레거시 호환 — 기존 배포에서 사용 중이면 그대로 두세요. 신규 배포는 위의 KRX_API_* 사용.
KRX_OPENAPI_AUTH_KEY=

# 임시로 KRX 호출을 꺼서 Yahoo 전용으로 되돌리고 싶을 때 true 로 설정.
# (인증키 만료, KRX 점검, 쿼터 소진 대응 스위치)
# 동일 의미의 블루프린트 이름 KRX_API_DISABLED 도 인식됩니다.
KRX_OPENAPI_DISABLED=false

# 공개(비인증) 엔드포인트 프록시 오버라이드 — data.krx.co.kr 사내 라우팅용 (거의 쓸 일 없음).
# 공개와 인증 엔드포인트는 호스트가 달라 하나의 KRX_API_BASE 로 공유하지 않습니다.
# KRX_PUBLIC_API_BASE=http://data.krx.co.kr

# ──────────────────────────────────────────────
# [5] ECOS 한국은행 경제통계 API
# ──────────────────────────────────────────────

# ECOS Open API 인증키 (ecos.bok.or.kr → 마이페이지 → 인증키 발급)
# 기준금리, 환율, M2 통화량, GDP 성장률, 수출입 데이터 조회에 사용
ECOS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ──────────────────────────────────────────────
# [6] Telegram Bot 알림 (이메일보다 빠른 실시간 알림, 선택)
# ──────────────────────────────────────────────

# 1. Telegram에서 @BotFather 검색 → /newbot → 이름 설정 → 토큰 발급 (5분 소요)
# 2. 봇과 대화 시작 후 https://api.telegram.org/bot<TOKEN>/getUpdates 에서 chat_id 확인
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=123456789

# 종목 픽 채널 ID (16:30 일일 픽 리포트 발송 대상 — 선택)
# 공개 채널: "@채널이름", 비공개 채널: "-100xxxxxxxxxx"
# 미설정 시 픽 리포트 전송이 스킵됩니다 (오류 없음)
TELEGRAM_PICK_CHANNEL_ID=-1003960015140

# Multi-channel routing (optional, gradual migration)
TELEGRAM_TRADE_CHANNEL_ID=
TELEGRAM_ANALYSIS_CHANNEL_ID=
TELEGRAM_INFO_CHANNEL_ID=
TELEGRAM_SYSTEM_CHANNEL_ID=
# Optional JSON override per category, e.g.
# CHANNEL_MAP={"TRADE":"-100...","ANALYSIS":"-100...","INFO":"-100...","SYSTEM":"-100..."}
CHANNEL_MAP=
# Category-specific rollout switches (fallback: CHANNEL_ENABLED)
TRADE_CHANNEL_ENABLED=true
ANALYSIS_CHANNEL_ENABLED=true
INFO_CHANNEL_ENABLED=true
SYSTEM_CHANNEL_ENABLED=true

# ──────────────────────────────────────────────
# [6] 이메일 알림 (선택)
# ──────────────────────────────────────────────

# Gmail 또는 SMTP 발신 계정
EMAIL_FROM=your-email@gmail.com

# Gmail 앱 비밀번호 (2단계 인증 후 앱 비밀번호 생성)
# Google 계정 → 보안 → 앱 비밀번호
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx

# 알림 수신 이메일 (발신과 동일해도 됨)
EMAIL_TO=your-email@gmail.com

# 일일 자동매매 리포트 수신 이메일 (미설정 시 EMAIL_USER로 발송)
REPORT_EMAIL=your-email@gmail.com

# ──────────────────────────────────────────────
# [6] Railway 배포 설정
# ──────────────────────────────────────────────

# Railway가 자동으로 설정합니다 — 직접 입력 불필요
# (Keep-Alive 자가 핑 URL로 사용됨)
# RAILWAY_STATIC_URL=https://your-app.up.railway.app

# 서버 포트 — Railway가 자동 주입하므로 입력 불필요
# PORT=3001

# 영구 데이터 저장 경로 (Railway Volume 마운트 시 필수)
# Railway Dashboard → Settings → Volumes → /app/data 마운트 후 설정
# 미설정 시 기본값 ./data (배포마다 초기화됨!)
PERSIST_DATA_DIR=/app/data

# Node 환경
NODE_ENV=production

# ──────────────────────────────────────────────
# [6.1] AI 추천 외부 데이터 (ADR-0011, PR-25-A)
# ──────────────────────────────────────────────
# Google Custom Search JSON API — AI 추천 universe 발굴 전용.
# 자동매매 경로(KIS/KRX) 와 분리되어 quota 침범 방지.
# 발급: https://programmablesearchengine.google.com/ (CX) +
#       https://console.cloud.google.com/ (API Key, Custom Search API 활성화)
# 무료 한도: 100 query/day, 초과 시 $5/1000 query
# GOOGLE_SEARCH_API_KEY=AIzaSy...
# GOOGLE_SEARCH_CX=017576662512468239146:omuauf_lfve

# AI 추천 외부 호출 일일 예산 (bucket 별 한도 override).
# 미설정 시 google_search 80 / naver_finance 1000 / krx_master_refresh 5.
# AI_DAILY_CALL_BUDGET=80

# ──────────────────────────────────────────────
# [7] 설정 순서 체크리스트
# ──────────────────────────────────────────────
#
#  □ 1. KIS Developers에서 앱 등록 → APP_KEY / APP_SECRET 발급
#  □ 2. KIS_IS_REAL=false 로 모의투자 먼저 시작
#  □ 3. AUTO_TRADE_ENABLED=false 로 Shadow 모드 검증
#  □ 4. DAILY_LOSS_LIMIT 설정 (5% 권장)
#  □ 5. Railway Variables 탭에 모든 값 입력
#  □ 6. 배포 후 /api/health 응답 확인
#  □ 7. Shadow 모드에서 1~2주 운용 후 실거래 전환 검토
#
# ⚠️  주의사항
#  - .env 파일을 절대 git에 커밋하지 마세요 (.gitignore 확인)
#  - KIS_IS_REAL=true 전환은 충분한 Shadow 검증 후에만
#  - DAILY_LOSS_LIMIT는 본인 리스크 허용 범위로 조정
# ============================================================
